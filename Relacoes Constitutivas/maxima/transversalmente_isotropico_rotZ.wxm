ev (     trigsimp(D[5,6]-DM[5,6] = 0)       ,      [Dxyxy = (1/2) * (Dxxxx - Dxxyy) , Dyyyy=Dxxxx, Dxxzz = Dyyzz, Dxzxz = Dyzyz]  )     ;
