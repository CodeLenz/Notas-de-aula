ev (     trigsimp(D[3,4]-DM[3,4] = 0)       ,      [Dxyxy = (1/2) * (Dxxxx - Dxxyy) , Dyyyy=Dxxxx, Dxxzz = Dyyzz]  )     ;
ev (     trigsimp(D[3,5]-DM[3,5] = 0)       ,      [Dxyxy = (1/2) * (Dxxxx - Dxxyy) , Dyyyy=Dxxxx, Dxxzz = Dyyzz]  )     ;
ev (     trigsimp(D[3,6]-DM[3,6] = 0)       ,      [Dxyxy = (1/2) * (Dxxxx - Dxxyy) , Dyyyy=Dxxxx, Dxxzz = Dyyzz]  )     ;
/* [wxMaxima: input   end   ] */


/* [wxMaxima: comment start ]
Acho que nunca os alunos ficaram tao felizes vendo tanto zeros....Vamos para a quarta linha..
