/* [wxMaxima: input   start ] */
ev (     trigsimp(D[4,4]-DM[4,4] = 0)       ,      [Dxyxy = (1/2) * (Dxxxx - Dxxyy) , Dyyyy=Dxxxx, Dxxzz = Dyyzz]  )     ;
