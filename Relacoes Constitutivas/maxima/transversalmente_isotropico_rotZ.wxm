/* [wxMaxima: input   start ] */
forma_invariante: teste: ev(D,[Dxyxy = (1/2) * (Dxxxx - Dxxyy) , Dyyyy=Dxxxx, Dxxzz = Dyyzz, Dxzxz = Dyzyz]);
